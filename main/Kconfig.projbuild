menu "Android TV Remote"

    config ATV_WIFI_SSID
        string "WiFi SSID"
        default ""
        help
            SSID of the WiFi network the ESP32 should join.

    config ATV_WIFI_PASSWORD
        string "WiFi password"
        default ""
        help
            Password of the WiFi network (leave empty for open networks).

    config ATV_TV_IP
        string "Android TV / Chromecast IP address"
        default "192.168.0.104"
        help
            LAN IP of the TV. Pairing uses port 6467, control port 6466.
            (mDNS discovery is a later stretch goal.)

endmenu
